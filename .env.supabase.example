# Supabase (primary) — pooler connection string.
# Copy to .env.supabase and fill in your project ref + password.
# Use the Supavisor pooler on port 6543 (transaction mode); the direct host is IPv6-only.
DATABASE_URL=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
