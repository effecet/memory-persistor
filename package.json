{
  "name": "memory-persistor",
  "version": "1.0.0",
  "description": "PostgreSQL-backed MCP memory server with thermal decay for Claude Code",
  "type": "module",
  "scripts": {
    "dev": "tsx src/mcp-server.ts",
    "build": "tsc",
    "test": "vitest run --exclude 'tests/integration/**'",
    "test:integration": "vitest run tests/integration/ --fileParallelism=false",
    "migrate": "drizzle-kit generate && drizzle-kit migrate",
    "seed": "tsx src/import.ts"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/effecet/memory-persistor.git"
  },
  "author": "effece",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/pg": "^8.18.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  }
}
